# Anthropic API (required for the morning briefing job — jobs/morning_briefing.js)
# Create a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Admin API
# Your store URL, e.g. https://your-store.myshopify.com (no trailing slash)
SHOPIFY_STORE_URL=https://your-store.myshopify.com

# Shopify Admin API access token (shpat_...)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Klaviyo private API key (pk_...)
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service role key (bypasses RLS — keep secret)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------------------
# Shopify OAuth app credentials (for the onboarding server)
# Create an app at https://partners.shopify.com and copy these values.
# Redirect URL to register in your Shopify app:
#   http://localhost:3000/auth/shopify/callback  (development)
#   https://your-domain.com/auth/shopify/callback  (production)
# -------------------------------------------------------------------
SHOPIFY_CLIENT_ID=your_shopify_app_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_app_client_secret
SHOPIFY_SCOPES=read_orders,read_analytics

# Public base URL of the onboarding server (no trailing slash)
APP_URL=http://localhost:3000

# Random secret for signing session cookies — use a long random string
SESSION_SECRET=replace_with_a_long_random_string

# Optional: override the onboarding server port (default: 3000)
# ONBOARDING_PORT=3000

